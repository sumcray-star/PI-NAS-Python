# Streamlit Configuration
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_LOGGER_LEVEL=info
PYTHONUNBUFFERED=1

# Raspberry Pi Network Storage Configuration
# Uncomment and fill these in to enable SMB connection
PI_SERVER_IP=192.168.1.100
PI_SHARE_NAME=media
PI_USERNAME=pi
PI_PASSWORD=your_pi_password_here
PI_MOUNT_POINT=/mnt/pi-nas
PI_PROTOCOL=smb
PI_PORT=445
PI_AUTO_MOUNT=true

# Application Settings
APP_TITLE=PI-NAS Media Server
APP_ENVIRONMENT=production

# File Upload Settings
MAX_UPLOAD_SIZE_MB=500
ALLOWED_EXTENSIONS=mp4,avi,mkv,mov,wmv,jpg,jpeg,png,gif,mp3,wav,pdf,txt

# Performance Settings
GENERATE_THUMBNAILS=true
ENABLE_CACHING=true
MAX_WORKERS=2

# Database/Storage Settings
DATA_DIR=./data
CONFIG_DIR=./config
MEDIA_DIR=./media
LOG_DIR=./logs
TEMP_DIR=./temp

# Security Settings
SESSION_TIMEOUT_MINUTES=120
PASSWORD_MIN_LENGTH=6
ALLOW_REGISTRATION=true

# Debug Mode (set to false in production)
DEBUG=false
